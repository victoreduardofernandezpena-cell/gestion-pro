generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  ventas
  almacen
  contabilidad
}

enum MovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHECK
  OTHER
}

enum PurchaseStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
}

enum CashTransactionType {
  CASH_IN
  CASH_OUT
  ADJUSTMENT
}

enum ExpensePaymentSource {
  BANK
  CASH_BOX
  OTHER
}

enum ExpenseCategory {
  RENT
  SALARY
  SERVICES
  TRANSPORT
  SUPPLIES
  MAINTENANCE
  TAXES
  OTHER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ventas)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  rnc       String?  @unique
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoices  Invoice[]
}

model Product {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique
  name               String
  description        String?
  cost               Decimal             @db.Decimal(12, 2)
  price              Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  minimumStock       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  invoiceItems       InvoiceItem[]
  purchaseItems      PurchaseItem[]
}

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  clientId      Int
  client        Client        @relation(fields: [clientId], references: [id])
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @db.Decimal(12, 2)
  discount      Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2) @default(0)
  balance       Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payments      Payment[]
}

model InvoiceItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  cost      Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
}

model Payment {
  id          Int           @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  notes       String?
  paymentDate DateTime
  createdAt   DateTime      @default(now())
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  rnc       String?    @unique
  phone     String?
  email     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
}

model Purchase {
  id             Int            @id @default(autoincrement())
  purchaseNumber String         @unique
  supplierId     Int
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  subtotal       Decimal        @db.Decimal(12, 2)
  tax            Decimal        @db.Decimal(12, 2)
  discount       Decimal        @db.Decimal(12, 2) @default(0)
  total          Decimal        @db.Decimal(12, 2)
  paidAmount     Decimal        @db.Decimal(12, 2) @default(0)
  balance        Decimal        @db.Decimal(12, 2)
  status         PurchaseStatus @default(PENDING)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          PurchaseItem[]
  payments       PurchasePayment[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  cost       Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
}

model PurchasePayment {
  id                Int              @id @default(autoincrement())
  purchaseId        Int
  purchase          Purchase         @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  bankAccountId     Int?
  bankAccount       BankAccount?     @relation(fields: [bankAccountId], references: [id])
  bankTransactionId Int?             @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  amount            Decimal          @db.Decimal(12, 2)
  method            PaymentMethod
  reference         String?
  notes             String?
  paymentDate       DateTime
  createdAt         DateTime         @default(now())
}

model BankAccount {
  id              Int               @id @default(autoincrement())
  name            String
  bankName        String
  accountNumber   String?
  currency        String            @default("DOP")
  initialBalance  Decimal           @db.Decimal(12, 2) @default(0)
  currentBalance  Decimal           @db.Decimal(12, 2) @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  transactions    BankTransaction[]
  expenses        Expense[]
  purchasePayments PurchasePayment[]
}

model BankTransaction {
  id              Int                 @id @default(autoincrement())
  bankAccountId   Int
  bankAccount     BankAccount         @relation(fields: [bankAccountId], references: [id])
  type            BankTransactionType
  amount          Decimal             @db.Decimal(12, 2)
  description     String?
  reference       String?
  transactionDate DateTime
  createdAt       DateTime            @default(now())
  purchasePayment PurchasePayment?
}

model CashBox {
  id              Int               @id @default(autoincrement())
  name            String
  description     String?
  initialBalance  Decimal           @db.Decimal(12, 2) @default(0)
  currentBalance  Decimal           @db.Decimal(12, 2) @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  transactions    CashTransaction[]
  expenses        Expense[]
}

model CashTransaction {
  id              Int                 @id @default(autoincrement())
  cashBoxId        Int
  cashBox          CashBox             @relation(fields: [cashBoxId], references: [id])
  type            CashTransactionType
  amount          Decimal             @db.Decimal(12, 2)
  description     String?
  reference       String?
  transactionDate DateTime
  createdAt       DateTime            @default(now())
}

model Expense {
  id            Int                  @id @default(autoincrement())
  category      ExpenseCategory
  description   String
  amount        Decimal              @db.Decimal(12, 2)
  paymentSource ExpensePaymentSource
  bankAccountId Int?
  bankAccount   BankAccount?         @relation(fields: [bankAccountId], references: [id])
  cashBoxId     Int?
  cashBox       CashBox?             @relation(fields: [cashBoxId], references: [id])
  reference     String?
  expenseDate   DateTime
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}
